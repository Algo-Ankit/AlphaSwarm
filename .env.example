# AlphaSwarm — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# ──────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────
# Async driver for FastAPI
DATABASE_URL=postgresql+asyncpg://alphaswarm:alphaswarm@localhost:5432/alphaswarm
# Sync driver for Alembic migrations only
DATABASE_SYNC_URL=postgresql://alphaswarm:alphaswarm@localhost:5432/alphaswarm

# ──────────────────────────────────────────
# REDIS
# ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ──────────────────────────────────────────
# ANTHROPIC — Claude
# https://console.anthropic.com/
# ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
STRATEGY_BUILDER_MODEL=claude-sonnet-4-6
ANALYSIS_MODEL=claude-haiku-4-5-20251001

# ──────────────────────────────────────────
# PLATFORM LLM (strategy builder) + STRICT-BYOK FOUNDER GATE
# Default = free local Ollama. Users bring their own key (Settings → AI);
# this platform key is the fallback ONLY for the founder account below.
# ──────────────────────────────────────────
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.1
# The ONLY email allowed to generate without its own key. Leave BLANK to enforce
# strict BYOK for everyone (recommended for public deploys). Put your real value
# in the gitignored .env, NOT here.
FOUNDER_EMAIL=

# ──────────────────────────────────────────
# ALPACA — Broker + US Market Data
# Paper: https://app.alpaca.markets/paper-trading
# Live:  https://app.alpaca.markets/brokerage/new-account
# ──────────────────────────────────────────
ALPACA_API_KEY=PKXXXXXXXXXXXXXXXXXXXXXXXX
ALPACA_SECRET_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_STREAM_URL=wss://stream.data.alpaca.markets/v2

# ──────────────────────────────────────────
# NEWS & MARKET INTELLIGENCE
# ──────────────────────────────────────────
# NewsAPI: https://newsapi.org/register (free tier: 100 req/day)
NEWS_API_KEY=...
# Alpha Vantage: https://www.alphavantage.co/support/#api-key (free tier: 25 req/day)
ALPHA_VANTAGE_KEY=...

# ──────────────────────────────────────────
# JWT AUTH — RS256
# Generate keys:
#   openssl genrsa -out /tmp/jwt_priv.pem 2048
#   openssl rsa -in /tmp/jwt_priv.pem -pubout -out /tmp/jwt_pub.pem
#   python -c "import base64,open; print(base64.b64encode(open('/tmp/jwt_priv.pem','rb').read()).decode())"
# ──────────────────────────────────────────
JWT_PRIVATE_KEY_BASE64=...
JWT_PUBLIC_KEY_BASE64=...
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ──────────────────────────────────────────
# BROKER KEY ENCRYPTION (Fernet AES-128)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ──────────────────────────────────────────
BROKER_KEY_ENCRYPTION_SECRET=...

# ──────────────────────────────────────────
# SENTRY (optional in dev, required in prod)
# ──────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ──────────────────────────────────────────
# BILLING (Razorpay) — required to deploy LIVE agents
# India-first recurring billing via UPI AutoPay / e-mandate.
# Dashboard: https://dashboard.razorpay.com/  (Settings → API Keys / Webhooks)
# ──────────────────────────────────────────
RAZORPAY_KEY_ID=                 # rzp_live_... / rzp_test_...
RAZORPAY_KEY_SECRET=
RAZORPAY_PLAN_QUANT=             # plan_... for the Quant Tier recurring plan
RAZORPAY_WEBHOOK_SECRET=        # webhook secret set in the Razorpay dashboard
RAZORPAY_SUBSCRIPTION_TOTAL_COUNT=12   # billing cycles per subscription

# ──────────────────────────────────────────
# TRANSACTIONAL EMAIL (SendGrid) — falls back to console stub if unset
# ──────────────────────────────────────────
SENDGRID_API_KEY=
EMAIL_FROM=no-reply@alphaswarm.io
EMAIL_FROM_NAME=AlphaSwarm

# ──────────────────────────────────────────
# LIVE INDIAN EXECUTION (Upstox OAuth) — register at https://upstox.com/developer/
# ──────────────────────────────────────────
UPSTOX_CLIENT_ID=
UPSTOX_CLIENT_SECRET=
APP_BASE_URL=http://localhost:3000

# ──────────────────────────────────────────
# APP CONFIG
# ──────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Default risk limits applied to every new strategy
DEFAULT_MAX_ORDER_NOTIONAL=1000.0
DEFAULT_MAX_DAILY_NOTIONAL=5000.0
PAPER_TRADING_ONLY=true

# ──────────────────────────────────────────
# INDIAN BROKER (per-tenant, stored encrypted in DB)
# Users enter these in /settings — NOT global platform keys.
# ZERODHA_KITE_API_KEY=    (example of what users will fill in settings)
# ZERODHA_KITE_SECRET=
# ──────────────────────────────────────────

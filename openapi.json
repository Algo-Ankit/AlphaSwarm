  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "LoginRequest": {
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "title": "Email"
          },
          "password": {
            "type": "string",
            "title": "Password"
          }
        },
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "title": "LoginRequest"
      },
      "RefreshRequest": {
        "properties": {
          "refresh_token": {
            "type": "string",
            "title": "Refresh Token"
          }
        },
        "type": "object",
        "required": [
          "refresh_token"
        ],
        "title": "RefreshRequest"
      },
      "RegisterRequest": {
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "title": "Email"
          },
          "password": {
            "type": "string",
            "maxLength": 128,
            "minLength": 8,
            "title": "Password"
          },
          "display_name": {
            "type": "string",
            "maxLength": 120,
            "minLength": 1,
            "title": "Display Name"
          },
          "tenant_name": {
            "type": "string",
            "maxLength": 120,
            "minLength": 1,
            "title": "Tenant Name"
          }
        },
        "type": "object",
        "required": [
          "email",
          "password",
          "display_name",
          "tenant_name"
        ],
        "title": "RegisterRequest"
      },
      "RunStatus": {
        "type": "string",
        "enum": [
          "queued",
          "running",
          "completed",
          "failed",
          "rejected"
        ],
        "title": "RunStatus"
      },
      "StrategyCreateRequest": {
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 120,
            "minLength": 3,
            "title": "Name"
          },
          "prompt": {
            "type": "string",
            "maxLength": 4000,
            "minLength": 10,
            "title": "Prompt"
          },
          "symbols": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Symbols"
          },
          "timeframe": {
            "type": "string",
            "maxLength": 20,
            "title": "Timeframe",
            "default": "1Min"
          },
          "risk": {
            "$ref": "#/components/schemas/StrategyRiskConfig"
          }
        },
        "type": "object",
        "required": [
          "name",
          "prompt"
        ],
        "title": "StrategyCreateRequest"
      },
      "StrategyResponse": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "tenant_id": {
            "type": "string",
            "title": "Tenant Id"
          },
          "owner_user_id": {
            "type": "string",
            "title": "Owner User Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "prompt": {
            "type": "string",
            "title": "Prompt"
          },
          "symbols": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Symbols"
          },
          "timeframe": {
            "type": "string",
            "title": "Timeframe"
          },
          "status": {
            "$ref": "#/components/schemas/StrategyStatus",
            "default": "draft"
          },
          "generated_logic": {
            "type": "string",
            "title": "Generated Logic"
          },
          "risk": {
            "$ref": "#/components/schemas/StrategyRiskConfig"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          }
        },
        "type": "object",
        "required": [
          "tenant_id",
          "owner_user_id",
          "name",
          "prompt",
          "symbols",
          "timeframe",
          "generated_logic",
          "risk"
        ],
        "title": "StrategyResponse"
      },
      "StrategyRiskConfig": {
        "properties": {
          "max_order_notional": {
            "type": "number",
            "exclusiveMinimum": 0.0,
            "title": "Max Order Notional",
            "default": 1000.0
          },
          "max_daily_notional": {
            "type": "number",
            "exclusiveMinimum": 0.0,
            "title": "Max Daily Notional",
            "default": 5000.0
          },
          "allowed_symbols": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Allowed Symbols"
          },
          "paper_trading_only": {
            "type": "boolean",
            "title": "Paper Trading Only",
            "default": true
          }
        },
        "type": "object",
        "title": "StrategyRiskConfig"
      },
      "StrategyRunRequest": {
        "properties": {
          "dry_run": {
            "type": "boolean",
            "title": "Dry Run",
            "default": true
          }
        },
        "type": "object",
        "title": "StrategyRunRequest"
      },
      "StrategyRunResponse": {
        "properties": {
          "run_id": {
            "type": "string",
            "title": "Run Id"
          },
          "strategy_id": {
            "type": "string",
            "title": "Strategy Id"
          },
          "task_id": {
            "type": "string",
            "title": "Task Id"
          },
          "status": {
            "$ref": "#/components/schemas/RunStatus"
          },
          "dry_run": {
            "type": "boolean",
            "title": "Dry Run"
          },
          "message": {
            "type": "string",
            "title": "Message"
          }
        },
        "type": "object",
        "required": [
          "run_id",
          "strategy_id",
          "task_id",
          "status",
          "dry_run",
          "message"
        ],
        "title": "StrategyRunResponse"
      },
      "StrategyStatus": {
        "type": "string",
        "enum": [
          "draft",
          "active",
          "paused",
          "archived"
        ],
        "title": "StrategyStatus"
      },
      "TaskStatusResponse": {
        "properties": {
          "task_id": {
            "type": "string",
            "title": "Task Id"
          },
          "celery_status": {
            "type": "string",
            "title": "Celery Status"
          },
          "result": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Result"
          }
        },
        "type": "object",
        "required": [
          "task_id",
          "celery_status"
        ],
        "title": "TaskStatusResponse"
      },
      "TokenResponse": {
        "properties": {
          "access_token": {
            "type": "string",
            "title": "Access Token"
          },
          "refresh_token": {
            "type": "string",
            "title": "Refresh Token"
          },
          "token_type": {
            "type": "string",
            "title": "Token Type",
            "default": "bearer"
          },
          "user_id": {
            "type": "string",
            "title": "User Id"
          },
          "tenant_id": {
            "type": "string",
            "title": "Tenant Id"
          },
          "email": {
            "type": "string",
            "title": "Email"
          },
          "role": {
            "type": "string",
            "title": "Role"
          }
        },
        "type": "object",
        "required": [
          "access_token",
          "refresh_token",
          "user_id",
          "tenant_id",
          "email",
          "role"
        ],
        "title": "TokenResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}
